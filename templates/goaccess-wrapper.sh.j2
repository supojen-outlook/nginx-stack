#!/bin/bash
# GoAccess 啟動腳本
# 使用 COMBINED 格式，依賴 goaccess.conf 中的 geoip-database 設定

LOG_FORMAT='%h %^[%d:%t %^] "%r" %s %b "%R" "%u" "~h{, }"'
DATE_FORMAT='%d/%b/%Y'
TIME_FORMAT='%H:%M:%S'

/usr/bin/goaccess /var/log/nginx/access.log \
    -o {{ goaccess_stats_path }} \
    --log-format="$LOG_FORMAT" \
    --date-format="$DATE_FORMAT" \
    --time-format="$TIME_FORMAT" \
    --real-time-html \
    --geoip-database=/var/lib/GeoIP/GeoLite2-City.mmdb \
    --ws-url=wss://{{ domain }}:443/goaccess-ws \
    --addr=127.0.0.1 \
    --port={{ goaccess_ws_port }}
