    #     proxy_set_header Host $host;
    #     proxy_buffering on;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }

    # 修正不帶斜線的 /admin 訪問 - 暫時禁用
    # location = /admin {
    #     return 301 /admin/;
    # }

    # 🚀 Client 前端 - 暫時禁用
    # location ^~ /shop/ {
    #     limit_req zone=general burst=20 nodelay;
    #     proxy_pass http://127.0.0.1:8082/;
    #     proxy_set_header Host $host;
    #     proxy_buffering on;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    #     proxy_set_header X-Forwarded-Prefix /shop;
    # }

    # ⚙️ API - 暫時禁用
    # location ^~ /api/ {
    #     limit_req zone=api_limit burst=10 nodelay;
    #     proxy_pass http://127.0.0.1:8080;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }

    # --- [第二優先順序：正則表達式攔截區] ---

    # 🚫 核心阻擋規則：使用 ~* (不分大小寫) 合併路徑
    location ~* ^/(?:\.(?:env|git|svn|hg|ds_store|idea|vscode)|config|wp-admin|wp-login\.php|admin\.php|phpmyadmin|mysql|xmlrpc\.php|info|phpinfo|shell|test|swagger|api/docs|console|manager|vendor|composer|package\.json|yarn\.lock|hello\.world)$ {
        return 404;
        log_not_found on;
    }

    # 🚫 阻擋惡意副檔名
    location ~* \.(?:php|jsp|asp|aspx|py|rb|pl|cgi|sh|sql|bak|log|conf|dist)$ {
        return 404;
        log_not_found on;
    }

    # --- [第三優先順序：預設處理] ---

    # ✅ 靜態入口網站 - 暫時禁用
